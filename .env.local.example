# 365 Happy 365 Environment Variables
# Copy this file to .env.local and fill in the values

# Site URL (used for OG tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://365happy365.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Newsletter API (optional - e.g., Mailchimp, ConvertKit)
NEWSLETTER_API_KEY=your_newsletter_api_key
NEWSLETTER_LIST_ID=your_list_id
